{
  "name": "matheme",
  "displayName": "Matheme",
  "description": "A Material-inspired color theme, product icon theme, and editor experience for VS Code",
  "version": "1.0.1",
  "publisher": "cdbattags",
  "license": "MIT",
  "author": "cdbattags",
  "packageManager": "pnpm@10.28.2",
  "icon": "logo.png",
  "galleryBanner": {
    "color": "#11131C",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cdbattags/matheme.git"
  },
  "bugs": {
    "url": "https://github.com/cdbattags/matheme/issues"
  },
  "engines": {
    "node": ">=22",
    "vscode": "^1.85.0"
  },
  "scripts": {
    "build": "run-s cleanup build:ts build:generate-themes build:icons build:file-icons build:assets",
    "build:icons": "tsx scripts/product-icons/build.ts",
    "build:file-icons": "tsx scripts/file-icons/build.ts",
    "build:assets": "tsx scripts/assets/generate.tsx",
    "cleanup": "rimraf build && rimraf dist",
    "build:ts": "tsgo -p tsconfig.json && cpy 'dist/**' build && cpy material-theme.config.json build",
    "build:generate-themes": "node dist/generator/cli.js",
    "sync:vscode-icons": "tsx scripts/file-icons/sync-vscode-icons.ts",
    "package": "vsce package",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "color-theme",
    "material",
    "product-icons",
    "file-icons",
    "dark-theme"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "main": "./build/material.theme.config",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "materialTheme.setAccent",
        "title": "Set accent color",
        "category": "Matheme"
      },
      {
        "command": "materialTheme.setFontPreset",
        "title": "Set font preset",
        "category": "Matheme"
      },
      {
        "command": "materialTheme.applyEditorPreset",
        "title": "Apply editor preset",
        "category": "Matheme"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Matheme",
      "properties": {
        "materialTheme.accent": {
          "type": "string",
          "default": "Blue",
          "description": "Current accent color (preset name or hex like #FF4081)",
          "scope": "window"
        },
        "materialTheme.decorations.todoHighlights": {
          "type": "boolean",
          "default": false,
          "description": "Highlight TODO, FIXME, HACK, NOTE, and BUG comments",
          "scope": "window"
        },
        "materialTheme.decorations.scopeDimming": {
          "type": "boolean",
          "default": false,
          "description": "Dim code outside the current scope/function",
          "scope": "window"
        },
        "materialTheme.defaults.smoothAnimations": {
          "type": "boolean",
          "default": false,
          "description": "Enable smooth cursor blinking, smooth caret animation, and smooth scrolling (editor, lists, terminal)",
          "scope": "window"
        },
        "materialTheme.defaults.bracketGuides": {
          "type": "boolean",
          "default": false,
          "description": "Enable bracket pair colorization and active bracket guides",
          "scope": "window"
        },
        "materialTheme.defaults.minimapOff": {
          "type": "boolean",
          "default": false,
          "description": "Disable the editor minimap",
          "scope": "window"
        },
        "materialTheme.defaults.fontDefaults": {
          "type": "boolean",
          "default": false,
          "description": "Apply Matheme font defaults: ligatures on, size 14, line height 1.6",
          "scope": "window"
        },
        "materialTheme.defaults.editorChrome": {
          "type": "boolean",
          "default": false,
          "description": "Apply Matheme editor chrome: sticky scroll, whitespace selection, rounded selection, tree indent 16, command center",
          "scope": "window"
        }
      }
    },
    "themes": [
      {
        "label": "Community Material Theme Default",
        "path": "./build/themes/Community-Material-Theme-Default.json",
        "uiTheme": "vs-dark"
      },
      {
        "label": "Community Material Theme Default High Contrast",
        "path": "./build/themes/Community-Material-Theme-Default-High-Contrast.json",
        "uiTheme": "vs-dark"
      },
      {
        "label": "Community Material Theme Darker",
        "path": "./build/themes/Community-Material-Theme-Darker.json",
        "uiTheme": "vs-dark"
      },
      {
        "label": "Community Material Theme Darker High Contrast",
        "path": "./build/themes/Community-Material-Theme-Darker-High-Contrast.json",
        "uiTheme": "vs-dark"
      },
      {
        "label": "Community Material Theme Palenight",
        "path": "./build/themes/Community-Material-Theme-Palenight.json",
        "uiTheme": "vs-dark"
      },
      {
        "label": "Community Material Theme Palenight High Contrast",
        "path": "./build/themes/Community-Material-Theme-Palenight-High-Contrast.json",
        "uiTheme": "vs-dark"
      },
      {
        "label": "Community Material Theme Ocean",
        "path": "./build/themes/Community-Material-Theme-Ocean.json",
        "uiTheme": "vs-dark"
      },
      {
        "label": "Community Material Theme Ocean High Contrast",
        "path": "./build/themes/Community-Material-Theme-Ocean-High-Contrast.json",
        "uiTheme": "vs-dark"
      },
      {
        "label": "Community Material Theme Lighter",
        "path": "./build/themes/Community-Material-Theme-Lighter.json",
        "uiTheme": "vs"
      },
      {
        "label": "Community Material Theme Lighter High Contrast",
        "path": "./build/themes/Community-Material-Theme-Lighter-High-Contrast.json",
        "uiTheme": "vs"
      },
      {
        "label": "Material Theme Deepforest",
        "path": "./build/themes/Material-Theme-Deepforest.json",
        "uiTheme": "vs-dark"
      },
      {
        "label": "Material Theme Deepforest High Contrast",
        "path": "./build/themes/Material-Theme-Deepforest-High-Contrast.json",
        "uiTheme": "vs-dark"
      },
      {
        "label": "Material Theme Midnight",
        "path": "./build/themes/Material-Theme-Midnight.json",
        "uiTheme": "vs-dark"
      },
      {
        "label": "Material Theme Midnight High Contrast",
        "path": "./build/themes/Material-Theme-Midnight-High-Contrast.json",
        "uiTheme": "vs-dark"
      },
      {
        "label": "Material Theme Rosewood",
        "path": "./build/themes/Material-Theme-Rosewood.json",
        "uiTheme": "vs-dark"
      },
      {
        "label": "Material Theme Rosewood High Contrast",
        "path": "./build/themes/Material-Theme-Rosewood-High-Contrast.json",
        "uiTheme": "vs-dark"
      }
    ],
    "productIconThemes": [
      {
        "id": "matheme-product-icons",
        "label": "Matheme Product Icons",
        "path": "./producticons/matheme-product-icon-theme.json"
      }
    ],
    "iconThemes": [
      {
        "id": "matheme-file-icons",
        "label": "Matheme File Icons",
        "path": "./fileicons/matheme-file-icon-theme.json"
      },
      {
        "id": "matheme-file-icons-mono",
        "label": "Matheme File Icons (Mono)",
        "path": "./fileicons/matheme-file-icon-theme-mono.json"
      }
    ]
  },
  "devDependencies": {
    "@iconify-json/catppuccin": "1.2.17",
    "@iconify/json": "2.2.454",
    "@resvg/resvg-js": "2.6.2",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "@typescript/native-preview": "^7.0.0-dev.20260324.1",
    "@vscode/vsce": "^3.7.1",
    "cpy-cli": "^7.0.0",
    "fs-extra": "^11.3.4",
    "npm-run-all": "^4.1.5",
    "oxlint": "^1.57.0",
    "rimraf": "^6.1.3",
    "satori": "0.26.0",
    "svgo": "4.0.1",
    "tsx": "4.21.0",
    "webfont": "11.2.26"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
